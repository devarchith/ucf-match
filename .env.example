# Local HTTP + DB checklist: docs/local-e2e-runbook.md
#
# --- Database (local) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ucf_match?schema=public"

# --- Next.js (typical) ---
# NODE_ENV is usually set by `next dev` / `next start`.

# --- Local dev bearer auth (development only) ---
# The API uses this when AUTH_MODE=dev (default in development if unset).
AUTH_MODE=dev
DEV_AUTH_ENABLED=true
# Shared secret; send as: Authorization: Bearer <DEV_AUTH_TOKEN>
DEV_AUTH_TOKEN=change-me-local-only
# Must match a User row id in the database (see seed below).
DEV_AUTH_USER_ID=dev-local-user
# Must be a real @ucf.edu string; validated for profile/preferences/week flows.
DEV_AUTH_UCF_EMAIL=devlocal@ucf.edu

# --- prisma/seed.ts (optional overrides) ---
# If unset, seed uses DEV_AUTH_* for the primary user when present.
# SEED_USER_ID=dev-local-user
# SEED_UCF_EMAIL=devlocal@ucf.edu
# Second user for match/report/block testing (IDs only; no extra token).
# SEED_PEER_USER_ID=dev-peer-user
# SEED_PEER_UCF_EMAIL=peer@ucf.edu
# Set to "true" to create a PENDING match between primary and peer (see docs/api-contracts.md).
# SEED_ACTIVE_MATCH=true
